<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AllyCare – Book a Trusted Companion in Minutes</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --navy: #1a2e6e;
    --blue: #2563eb;
    --blue-light: #3b82f6;
    --green: #16a34a;
    --green-light: #22c55e;
    --orange: #f97316;
    --bg: #f8faff;
    --white: #ffffff;
    --gray-50: #f9fafb;
    --gray-100: #f3f4f6;
    --gray-200: #e5e7eb;
    --gray-400: #9ca3af;
    --gray-600: #4b5563;
    --gray-800: #1f2937;
    --radius: 12px;
    --shadow: 0 4px 24px rgba(37,99,235,0.08);
    --shadow-md: 0 8px 32px rgba(37,99,235,0.12);
  }
  html { scroll-behavior: smooth; }
  body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--gray-800); line-height: 1.6; }

  /* ── NAV ── */
  nav {
    background: var(--white);
    box-shadow: 0 1px 12px rgba(0,0,0,0.07);
    position: sticky; top: 0; z-index: 100;
    padding: 0 5%;
    display: flex; align-items: center; justify-content: space-between;
    height: 70px;
  }
  .logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
  .logo-icon { width: 42px; height: 42px; }
  .logo-text { display: flex; flex-direction: column; }
  .logo-text span:first-child { font-family: 'Poppins', sans-serif; font-size: 1.35rem; font-weight: 700; }
  .logo-text span:first-child em { color: var(--orange); font-style: normal; }
  .logo-text small { font-size: 0.62rem; color: var(--gray-600); letter-spacing: 0.01em; margin-top: -2px; }
  .nav-links { display: flex; align-items: center; gap: 28px; list-style: none; }
  .nav-links a { text-decoration: none; color: var(--gray-800); font-size: 0.88rem; font-weight: 500; transition: color 0.2s; }
  .nav-links a:hover { color: var(--blue); }
  .btn-whatsapp {
    background: var(--navy);
    color: var(--white);
    border: none; cursor: pointer;
    padding: 10px 20px; border-radius: 8px;
    font-size: 0.85rem; font-weight: 600;
    display: flex; align-items: center; gap: 7px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .btn-whatsapp:hover { background: var(--blue); }
  .whatsapp-icon { width: 17px; height: 17px; }

  /* ── HERO ── */
  .hero {
    background: var(--white);
    margin: 24px 5%;
    border-radius: 18px;
    padding: 48px 40px;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 32px;
    align-items: center;
    box-shadow: var(--shadow);
  }
  .hero-left h1 { font-family: 'Poppins', sans-serif; font-size: 2.4rem; font-weight: 800; color: var(--gray-800); line-height: 1.2; margin-bottom: 16px; }
  .hero-left p { color: var(--gray-600); font-size: 1rem; margin-bottom: 28px; }
  .hero-badges { display: flex; gap: 20px; flex-wrap: wrap; }
  .badge { display: flex; flex-direction: column; align-items: center; gap: 6px; font-size: 0.78rem; font-weight: 600; color: var(--gray-800); text-align: center; }
  .badge svg { width: 32px; height: 32px; color: var(--blue); }
  .hero-img img { width: 100%; border-radius: 14px; object-fit: cover; max-height: 280px; }
  .hero-trust { background: var(--gray-50); border-radius: 14px; padding: 28px 24px; }
  .hero-trust .shield { display: flex; justify-content: center; margin-bottom: 14px; }
  .hero-trust h3 { font-size: 0.95rem; font-weight: 700; text-align: center; margin-bottom: 14px; color: var(--navy); }
  .trust-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .trust-list li { font-size: 0.85rem; display: flex; align-items: center; gap: 8px; color: var(--gray-600); }
  .trust-list li::before { content: '✓'; color: var(--blue); font-weight: 700; flex-shrink: 0; }

  /* ── WHATSAPP BANNER ── */
  .wa-banner {
    background: var(--white);
    margin: 0 5% 24px;
    border-radius: 12px;
    padding: 18px 32px;
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    box-shadow: var(--shadow);
    border-left: 4px solid var(--green);
  }
  .wa-banner-left { display: flex; align-items: center; gap: 14px; }
  .wa-banner-left svg { width: 36px; height: 36px; color: var(--green); flex-shrink: 0; }
  .wa-banner-left strong { font-size: 0.95rem; display: block; margin-bottom: 2px; }
  .wa-banner-left span { font-size: 0.82rem; color: var(--gray-600); }
  .btn-green {
    background: var(--green);
    color: var(--white);
    border: none; cursor: pointer;
    padding: 11px 22px; border-radius: 8px;
    font-size: 0.85rem; font-weight: 600;
    display: flex; align-items: center; gap: 7px;
    white-space: nowrap;
    text-decoration: none;
    transition: background 0.2s;
  }
  .btn-green:hover { background: #15803d; }

  /* ── BOOKING SECTION ── */
  .booking-section { margin: 0 5% 48px; display: grid; grid-template-columns: 1fr 300px; gap: 24px; }
  .booking-card { background: var(--white); border-radius: 16px; box-shadow: var(--shadow); padding: 36px; }
  .booking-card h2 { font-family: 'Poppins', sans-serif; font-size: 1.6rem; font-weight: 700; text-align: center; color: var(--gray-800); margin-bottom: 4px; }
  .booking-card .subtitle { text-align: center; font-size: 0.85rem; color: var(--gray-400); margin-bottom: 28px; }
  .steps-nav { display: flex; align-items: center; gap: 0; margin-bottom: 32px; }
  .step-item { display: flex; align-items: center; gap: 7px; font-size: 0.82rem; }
  .step-num { width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.8rem; flex-shrink: 0; }
  .step-item.active .step-num { background: var(--navy); color: var(--white); }
  .step-item:not(.active) .step-num { background: var(--gray-100); color: var(--gray-400); }
  .step-item.active { color: var(--gray-800); font-weight: 600; }
  .step-item:not(.active) { color: var(--gray-400); }
  .step-divider { flex: 1; height: 1px; background: var(--gray-200); min-width: 12px; }
  .booking-question { font-weight: 600; margin-bottom: 18px; font-size: 0.95rem; }
  .service-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-bottom: 28px; }
  .service-tile {
    border: 2px solid var(--gray-200);
    border-radius: 10px; padding: 16px 8px;
    text-align: center; cursor: pointer;
    transition: all 0.18s;
    font-size: 0.75rem; font-weight: 600; color: var(--gray-800);
    display: flex; flex-direction: column; align-items: center; gap: 8px;
  }
  .service-tile:hover { border-color: var(--blue); background: #eff6ff; }
  .service-tile.selected { border-color: var(--navy); background: #eff6ff; }
  .service-tile svg { width: 28px; height: 28px; color: var(--blue); }
  .btn-next {
    background: var(--navy);
    color: var(--white); border: none; cursor: pointer;
    padding: 13px 32px; border-radius: 8px;
    font-size: 0.9rem; font-weight: 600;
    display: flex; align-items: center; gap: 8px;
    margin-left: auto;
    transition: background 0.2s;
  }
  .btn-next:hover { background: var(--blue); }
  .accordion-list { display: flex; flex-direction: column; gap: 10px; margin-top: 8px; }
  .accordion-item {
    border: 1px solid var(--gray-200); border-radius: 10px;
    padding: 16px 20px; cursor: pointer;
    display: flex; align-items: center; justify-content: space-between;
  }
  .accordion-item:hover { border-color: var(--blue-light); }
  .acc-left { display: flex; align-items: flex-start; gap: 12px; }
  .acc-num { width: 26px; height: 26px; border-radius: 50%; background: var(--gray-100); display: flex; align-items: center; justify-content: center; font-size: 0.78rem; font-weight: 700; color: var(--gray-600); flex-shrink: 0; }
  .acc-text strong { font-size: 0.88rem; font-weight: 600; display: block; }
  .acc-text span { font-size: 0.78rem; color: var(--gray-400); }

  /* Sidebar */
  .booking-sidebar { display: flex; flex-direction: column; gap: 16px; }
  .sidebar-card { background: var(--white); border-radius: 14px; box-shadow: var(--shadow); padding: 24px; }
  .sidebar-card h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 16px; color: var(--gray-800); }
  .summary-row { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 12px; font-size: 0.82rem; }
  .summary-row svg { width: 16px; height: 16px; color: var(--blue); flex-shrink: 0; margin-top: 2px; }
  .summary-row .sr-label { color: var(--gray-400); font-size: 0.73rem; display: block; }
  .summary-row .sr-val { font-weight: 600; color: var(--gray-800); }
  .duration-badge { background: var(--navy); color: var(--white); border-radius: 8px; padding: 10px 14px; font-size: 0.85rem; font-weight: 700; margin-top: 8px; }
  .sidebar-card .need-help { font-size: 0.82rem; color: var(--gray-600); text-align: center; margin-bottom: 12px; }
  .vision-quote { font-style: italic; font-size: 0.82rem; color: var(--gray-600); border-left: 3px solid var(--blue-light); padding-left: 12px; margin-top: 8px; }

  /* ── SERVICES ── */
  .services-section { padding: 60px 5%; background: var(--white); margin-bottom: 0; }
  .section-header { text-align: center; margin-bottom: 40px; }
  .section-header h2 { font-family: 'Poppins', sans-serif; font-size: 1.8rem; font-weight: 700; color: var(--blue); margin-bottom: 8px; }
  .section-header p { color: var(--gray-600); font-size: 0.9rem; }
  .services-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px; }
  .service-card { background: var(--gray-50); border-radius: 14px; padding: 24px 18px; transition: box-shadow 0.2s, transform 0.2s; }
  .service-card:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); }
  .service-card .sc-icon { width: 48px; height: 48px; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-bottom: 14px; }
  .service-card h4 { font-size: 0.9rem; font-weight: 700; margin-bottom: 10px; color: var(--gray-800); }
  .service-card ul { list-style: none; display: flex; flex-direction: column; gap: 5px; }
  .service-card ul li { font-size: 0.78rem; color: var(--gray-600); display: flex; align-items: center; gap: 6px; }
  .service-card ul li::before { content: '✓'; font-weight: 700; flex-shrink: 0; }
  .sc-blue .sc-icon { background: #eff6ff; }
  .sc-blue .sc-icon svg, .sc-blue ul li::before { color: var(--blue); }
  .sc-teal .sc-icon { background: #f0fdfa; }
  .sc-teal .sc-icon svg, .sc-teal ul li::before { color: #0d9488; }
  .sc-orange .sc-icon { background: #fff7ed; }
  .sc-orange .sc-icon svg, .sc-orange ul li::before { color: var(--orange); }
  .sc-purple .sc-icon { background: #faf5ff; }
  .sc-purple .sc-icon svg, .sc-purple ul li::before { color: #7c3aed; }
  .sc-pink .sc-icon { background: #fdf2f8; }
  .sc-pink .sc-icon svg, .sc-pink ul li::before { color: #db2777; }

  /* ── ABOUT / TESTIMONIALS / HOW IT WORKS ── */
  .info-section { padding: 60px 5%; display: grid; grid-template-columns: 1fr 1.2fr 1fr; gap: 40px; background: var(--bg); }
  .info-col h2 { font-family: 'Poppins', sans-serif; font-size: 1.2rem; font-weight: 700; color: var(--blue); margin-bottom: 16px; }
  .about-para { font-size: 0.88rem; color: var(--gray-600); margin-bottom: 14px; }
  .about-checks { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .about-checks li { font-size: 0.84rem; display: flex; gap: 8px; }
  .about-checks li::before { content: '✓'; color: var(--blue); font-weight: 700; }
  .stars { color: #f59e0b; font-size: 1.3rem; margin-bottom: 16px; }
  .testimonial { background: var(--white); border-radius: 12px; padding: 18px; margin-bottom: 12px; box-shadow: var(--shadow); }
  .testimonial p { font-size: 0.83rem; color: var(--gray-600); margin-bottom: 8px; font-style: italic; }
  .testimonial strong { font-size: 0.8rem; color: var(--gray-800); }
  .how-steps { display: flex; flex-direction: column; gap: 16px; margin-top: 4px; }
  .how-step { display: flex; gap: 14px; align-items: flex-start; }
  .how-num { width: 32px; height: 32px; border-radius: 50%; background: var(--navy); color: var(--white); font-weight: 700; font-size: 0.85rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .how-step p { font-size: 0.85rem; color: var(--gray-600); }

  /* ── CTA BANNER ── */
  .cta-banner {
    background: var(--navy); color: var(--white);
    padding: 48px 5%;
    display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap;
  }
  .cta-banner .cta-left { display: flex; align-items: center; gap: 16px; }
  .cta-banner .shield { width: 48px; height: 48px; flex-shrink: 0; }
  .cta-banner h2 { font-family: 'Poppins', sans-serif; font-size: 1.5rem; font-weight: 700; }
  .cta-banner p { font-size: 0.88rem; opacity: 0.8; margin-top: 4px; }
  .cta-btns { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn-white { background: var(--white); color: var(--navy); border: none; cursor: pointer; padding: 13px 28px; border-radius: 8px; font-size: 0.9rem; font-weight: 700; text-decoration: none; transition: background 0.2s; }
  .btn-white:hover { background: var(--gray-100); }

  /* ── FOOTER BAR ── */
  .footer-bar { background: var(--navy); border-top: 1px solid rgba(255,255,255,0.1); padding: 18px 5%; display: flex; align-items: center; justify-content: space-around; flex-wrap: wrap; gap: 16px; }
  .footer-badge { display: flex; align-items: center; gap: 8px; color: var(--white); font-size: 0.8rem; }
  .footer-badge svg { width: 22px; height: 22px; opacity: 0.85; }

  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; }
    .hero-img { display: none; }
    .booking-section { grid-template-columns: 1fr; }
    .booking-sidebar { display: none; }
    .services-grid { grid-template-columns: repeat(2, 1fr); }
    .info-section { grid-template-columns: 1fr; }
    .service-grid { grid-template-columns: repeat(3, 1fr); }
    .nav-links { display: none; }
  }
</style>
</head>
